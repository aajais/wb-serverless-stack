# Copy to .env and fill in. Loaded by python-dotenv in every entrypoint.

# --- W&B credentials ---
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=sql-copilot-bird

# --- Serverless RL ---
WANDB_BASE_URL=https://api.wandb.ai
WANDB_TRAINING_URL=https://api.training.wandb.ai/v1

# --- Run knobs (overridable on CLI) ---
SQL_MODEL_NAME=sql-copilot-001
BASE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
TRAIN_MAX_STEPS=100
EVAL_EVERY_N_STEPS=25
ROLLOUTS_PER_PROMPT=8
PROMPTS_PER_STEP=4
LEARNING_RATE=1e-5
SAMPLING_TEMPERATURE=1.0
MAX_COMPLETION_TOKENS=512
SANDBOX_POOL_SIZE=12
SQL_TIMEOUT_SEC=5
SANDBOX_CONTAINER_IMAGE=python:3.11
# Pooled sandboxes live for the whole run; keep this above your run's wall
# time or the backend will reap them mid-training ("Socket closed").
SANDBOX_MAX_LIFETIME_SEC=14400
# Cap concurrent sandbox boots to avoid thundering-herd pip/gRPC failures.
SANDBOX_BOOT_CONCURRENCY=8
WEAVE_ROLLOUT_SAMPLE_RATE=0.25
TRAIN_SEED=0
DATA_SOURCE=train

# --- Data paths ---
BIRD_DATA_DIR=./data/bird
BIRD_DEV_SUBSET=./data/dev_200.jsonl

# --- Eval / baseline endpoint (scripts/make_baseline.py, scripts/smoke_eval.py).
#     EVAL_MODEL / EVAL_API_KEY fall back to BASE_MODEL / WANDB_API_KEY. ---
EVAL_ENDPOINT=https://api.inference.wandb.ai/v1
EVAL_MODEL=
EVAL_API_KEY=
EVAL_NAME=bird-dev-200-baseline
SMOKE_EVAL_N=10
BASELINE_OUT_PATH=./out/baseline.json

# --- Local TRL + vLLM fallback (src/train_local.py).
#     LOCAL_MODEL falls back to BASE_MODEL when unset. ---
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
LOCAL_MODEL=
TRAIN_LOCAL_MAX_STEPS=100

# --- W&B Registry: one aggregated artifact per split, lazy per-entry pulls. ---
# Upload once via:
#   python -m data.registry_uploader upload-dataset \
#       --collection $BIRD_REGISTRY_DEV_COLLECTION --root ./data/bird/dev
#   python -m data.registry_uploader upload-dataset \
#       --collection $BIRD_REGISTRY_TRAIN_COLLECTION --root ./data/bird/train
# Each upload produces ONE artifact (one collection version) containing every
# *.sqlite as an internal entry at ``<db_id>/<db_id>.sqlite``. Sandboxes pull
# only the entry they need per rollout via Artifact.get_entry(name).download().
BIRD_REGISTRY_NAME=
BIRD_REGISTRY_DEV_COLLECTION=bird-dev
BIRD_REGISTRY_TRAIN_COLLECTION=bird-train
BIRD_REGISTRY_COLLECTION=
BIRD_REGISTRY_VERSION=latest

# --- data/registry_uploader.py CLI defaults (only used by the uploader). ---
BIRD_REGISTRY_UPLOAD_PATH=./data/bird
BIRD_REGISTRY_ARTIFACT_TYPE=dataset
BIRD_REGISTRY_DOWNLOAD_ROOT=./data/bird
